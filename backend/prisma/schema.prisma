// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  isAdmin      Boolean  @default(false) @map("is_admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  // Scheduling Feature
  slug          String?  @unique
  whatsapp      String?

  // Directory & Settings
  showInDirectory Boolean @default(true) @map("show_in_directory")
  autoConfirm     Boolean @default(false) @map("auto_confirm")
  profession      String?
  category        String?
  status          String  @default("ACTIVE") // ACTIVE | PENDING_APPROVAL

  businessHours BusinessHours[]
  appointments  Appointment[]
  services      UserService[]

  @@map("users")
}

model Profession {
  id       String              @id @default(uuid())
  name     String
  category String
  services ProfessionService[]

  @@map("professions")
}

model ProfessionService {
  id           String     @id @default(uuid())
  professionId String     @map("profession_id")
  profession   Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)
  name         String

  @@map("profession_services")
}

model UserService {
  id     String  @id @default(uuid())
  userId String  @map("user_id")
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  price  Decimal? @db.Decimal(10, 2)

  @@map("user_services")
}


model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model BusinessHours {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  startTime String   // e.g., "09:00"
  endTime   String   // e.g., "18:00"
  whatsappEnabled Boolean @default(false)
  
  @@map("business_hours")
}

model Appointment {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  startTime   String   // e.g., "14:00"
  endTime     String   // e.g., "10:00"
  
  clientName String
  clientEmail String
  clientWhatsapp String? // Added for WhatsApp integration

  status     String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("appointments")
}
